# Data, Models, and Local Databases
apex_data/
*.pkl
# Ignore all json files globally EXCEPT specific ones (like package.json, which is handled below if needed)
*.json
*.jsonl
*.npy
# But allow specific configuration JSONs if any exist at the root
!backend/package.json
!frontend/package.json
!frontend/tsconfig.json
!backend/tsconfig.json

# Logs
logs/
*.log

# OS Files
.DS_Store
Thumbs.db
._*

# IDEs
.vscode/
.idea/
*.swp
*.swo

# Project-specific large files
embedding_cache.pkl
